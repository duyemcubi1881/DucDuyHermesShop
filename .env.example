# ─────────────────────────────────────────────────────────────
# CONFIGURATION FOR STANDALONE AIMLOCK PRO SHOP WEB
# ─────────────────────────────────────────────────────────────

# Web server port (Render will automatically pass PORT)
PORT=8080

# Bank Account Details for VietQR code generation
BANK_NUMBER=00000000000
BANK_NAME=tpbank
ACCOUNT_NAME=NGO DUC DUY
BANK_DISPLAY=TP BANK

# SePay Automated Balance API Settings
# SePay API Token (e.g. Bearer XXX) from my.sepay.vn
SEPAY_TOKEN=your_sepay_api_token_here

# Deposit Configs
MIN_DEPOSIT=5000
ORDER_EXPIRE_MINUTES=15
DEPOSIT_UNIQUE_SUFFIX=1

# AimLock Pro Backend API Settings
API_AIMBOT_BASE=https://aovduy-h4bn.onrender.com
API_ADMIN_USER=admin_username
API_ADMIN_PASS=admin_password

# General Support Information
SUPPORT_TEXT=Hỗ trợ: Liên hệ Admin qua Telegram/Zalo
